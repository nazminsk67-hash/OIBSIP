# ── Server ──────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ──────────────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/pizza-delivery

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

# ── Email (Nodemailer – use Ethereal for dev or your SMTP) ───────
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_ethereal_user@ethereal.email
SMTP_PASS=your_ethereal_password
EMAIL_FROM=noreply@pizzadelivery.com

# ── Client URL (for email links) ─────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── Admin Email (low-stock alert recipient) ───────────────────────
ADMIN_EMAIL=admin@pizzadelivery.com

# ── Razorpay ─────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── Inventory thresholds (units) ─────────────────────────────────
STOCK_ALERT_THRESHOLD=20
